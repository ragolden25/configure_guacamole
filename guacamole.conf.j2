# nginx.conf.j2 — unified config for functional + hardened images

# Functional images (ccop/*) run master as root and drop to nginx user.
# Hardened images (nucleus/*) run entirely as UID 65532, so we REMOVE the user directive.
{% if nginx_image.startswith('ccop/') %}
user nginx;
{% endif %}

worker_processes auto;
error_log /var/log/nginx/error.log;
pid /run/nginx.pid;

# Load dynamic modules
include /usr/share/nginx/modules/*.conf;

events {
    worker_connections 1024;
}

http {
    log_format  main  '$remote_addr - $remote_user [$time_local] "$request" '
                      '$status $body_bytes_sent "$http_referer" '
                      '"$http_user_agent" "$http_x_forwarded_for"';

    access_log  /var/log/nginx/access.log  main;

    sendfile            on;
    tcp_nopush          on;
    tcp_nodelay         on;
    keepalive_timeout   65;
    types_hash_max_size 4096;

    include             /etc/nginx/mime.types;
    default_type        application/octet-stream;

    # Load reverse-proxy configs (guacamole.conf)
    include /etc/nginx/conf.d/*.conf;

    # Functional images include the default HTML server block.
    # Hardened images remove it entirely.
    {% if nginx_image.startswith('ccop/') %}
    server {
        listen       80;
        server_name  _;
        root         /usr/share/nginx/html;

        error_page 404 /404.html;
        location = /404.html { }

        error_page 500 502 503 504 /50x.html;
        location = /50x.html { }
    }
    {% endif %}
}
